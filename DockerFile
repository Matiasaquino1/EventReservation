# Build stage
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY ["src/EventReservations.Api/EventReservations.csproj", "src/EventReservations.Api/"]
RUN dotnet restore "src/EventReservations.Api/EventReservations.csproj"

COPY . .
WORKDIR "/src/src/EventReservations.Api"
RUN dotnet publish "EventReservations.csproj" -c Release -o /app/publish

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:9.0
WORKDIR /app
COPY --from=build /app/publish .

ENV ASPNETCORE_URLS=http://+:10000
EXPOSE 10000

ENTRYPOINT ["dotnet", "EventReservations.dll"]